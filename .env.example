# Copy to .env and fill in — OR set these in your host's dashboard
# (Vercel / Netlify / Cloudflare Pages). Values here override config.ts.

# --- Client-safe (bundled into browser) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...
VITE_ADMIN_EMAIL=admin@example.com

# --- Server-side only (never sent to browser) ---
# The /api/pan-find route reads these on the server.
# ⚠️ DO NOT add a VITE_ prefix — that would leak the keys into the browser bundle.
# Add these in your hosting dashboard (Vercel / Netlify / Cloudflare) → Environment Variables.
PAN_API_KEY=
PAN_API_SECRET=

# Payment gateway (wallet top-up). Server-side only.
# Edit the endpoint paths / field names in config.ts PAYMENT block if your
# provider differs. Defaults target RapidX-style form-encoded UPI PSPs.
PAYMENT_API_URL=https://pay.rapidxservices.in
PAYMENT_USER_TOKEN=
PAYMENT_API_SECRET=

# Optional server fallbacks — only needed if VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY
# are not set at build time on the host. The server route reads either variant.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=